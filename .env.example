# Ai Arbuz Provider Api — environment (12-factor). Copy to .env and edit.

# ── Required secrets ─────────────────────────────────────────────────────────
# Master encryption key for upstream API keys at rest.
# 32 bytes = 64 hex chars OR 44 base64 chars. Generate, e.g.:
#   openssl rand -hex 32
ARBUZ_MASTER_KEY=

# Admin panel credentials. The password is REQUIRED and has no default:
# the app refuses to start with an empty, too-short (<8) or placeholder value.
ARBUZ_ADMIN_LOGIN=admin
ARBUZ_ADMIN_PASSWORD=

# ── Networking ───────────────────────────────────────────────────────────────
# Internal HTTP listen address. Keep it on a local/internal port and put a
# reverse proxy (TLS, domain) in front. Change the port freely to avoid
# collisions with other services already running on the host.
ARBUZ_LISTEN=:8080

# Public base URL of this router (your domain, no trailing slash).
ARBUZ_PUBLIC_URL=https://your-domain.example

# ── Storage ──────────────────────────────────────────────────────────────────
ARBUZ_DB_PATH=./data/arbuz.db

# ── Behavior ─────────────────────────────────────────────────────────────────
# Prefix for issued keys.
ARBUZ_ISSUED_KEY_PREFIX=sk-arbuz

# Logging level: debug | info | warn | error
ARBUZ_LOG_LEVEL=info

# Response cache: enabled | disabled
ARBUZ_CACHE_ENABLED=enabled
ARBUZ_CACHE_TTL_SECONDS=300

# Response guard: block | alert | off
ARBUZ_GUARD_MODE=block

# Limiter behavior when a usage read errors:
#   closed (default — refuse, protects upstream spend) | open (permissive)
ARBUZ_LIMIT_FAIL=closed

# Capture full request/response bodies in logs (secrets masked). Default off.
ARBUZ_LOG_PAYLOAD=disabled

# Inbound request body size cap, bytes (default 16 MiB).
ARBUZ_MAX_BODY_BYTES=16777216
